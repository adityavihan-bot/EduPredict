{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Streamlit App",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe -m streamlit run app.py",
      "group": {
        "kind": "build",
        "isDefault": true
